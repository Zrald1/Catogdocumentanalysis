{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CATOG Intelligent Enterprise Solution",
  "version": "0.1.0",
  "identifier": "com.catog.intelligententerprisesolution",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CATOG Intelligent Enterprise Solution",
        "label": "main",
        "width": 1600,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 720,
        "additionalBrowserArgs": "--disable-gpu --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection",
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.mac.plist"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
